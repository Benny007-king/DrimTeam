rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // האם המשתמש המחובר הוא מנהל? נקבע ע"י Custom Claim (admin:true) בטוקן.
    // נשמרת גם בדיקת קולקציית admins כגיבוי (אם הטוקן עוד לא רוענן).
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.admin == true
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // משחקים וטורנירים — קריאה לכולם (תוכן ציבורי)
    match /app/games        { allow read: if true; }
    match /app/tournaments  { allow read: if true; }
    // תבניות לולאת משחקים — קריאה לכולם (לתצוגת "ייפתח בקרוב" בלוח); כתיבה למנהל בלבד (דרך app/{doc})
    match /app/recurring    { allow read: if true; }
    // הגדרות (כולל קישורי וואטסאפ) ורישומים מקומיים — קריאה למנהלים בלבד
    match /app/settings     { allow read: if isAdmin(); }
    match /app/regs         { allow read: if isAdmin(); }
    // כתיבה לכל מסמכי app — למנהלים בלבד
    match /app/{doc} {
      allow write: if isAdmin();
    }

    // רשימת מנהלים מורשים — נשלטת מ-Console בלבד
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // הרשמות — רק משתמש מחובר יוצר (מונע ספאם אנונימי), רק מנהל קורא/מוחק
    match /registrations/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // חברים (חתמו על תקנון) — כל משתמש כותב/קורא/מוחק את עצמו, מנהל קורא/מוחק הכל
    match /members/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['uid','name','phone','email','city','idNumber','sport','termsAccepted','health','photo','rating','createdAt','punches']);
      allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // מונה נרשמים לכל משחק (לציבור) — כתיבה רק כצעד ±1 על השדה count (מונע זיוף ספירה)
    match /gameStats/{gameId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['count'])
        && (request.resource.data.count == resource.data.count + 1
            || request.resource.data.count == resource.data.count - 1);
      allow delete: if isAdmin();
    }

    // סוד OTP של מנהל — נגיש רק לבעל החשבון
    match /adminOtp/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // גלריה — קריאה לכולם, כתיבה למנהלים בלבד
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // תוצאות משחקים (מלך שערים / קבוצה מנצחת) — קריאה לכולם, כתיבה למנהלים
    match /results/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // הזמנות/תשלומים — נכתבות ע"י השרת (Cloud Functions) בלבד
    match /orders/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // צ'אט קהילתי — קריאה וכתיבה למשתמשים מחוברים בלבד; מחיקה למנהל
    match /chat/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // צ'אט אישי (1:1) — קריאה/כתיבה רק למשתתפי השיחה
    match /dms/{id} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update, delete: if false;
    }

    // ספריית משתמשים (שם בלבד) — לחיפוש לשליחת הודעה. קריאה למחוברים, כתיבה לבעלים
    match /directory/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // צ'אטים קבוצתיים — ניהול ע"י מנהל; קריאה לחברי הקבוצה
    match /groups/{gid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.members);
      allow create, update, delete: if isAdmin();
      match /messages/{mid} {
        allow read: if request.auth != null
          && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/groups/$(gid)).data.members);
        allow create: if request.auth != null
          && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/groups/$(gid)).data.members)
          && request.resource.data.from == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }
  }
}
