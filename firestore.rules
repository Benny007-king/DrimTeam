rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // האם המשתמש המחובר הוא מנהל? נקבע ע"י Custom Claim (admin:true) בטוקן.
    // נשמרת גם בדיקת קולקציית admins כגיבוי (אם הטוקן עוד לא רוענן).
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.admin == true
            || exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // טורנירים, משחקים, הגדרות — קריאה לכולם, כתיבה למנהלים בלבד
    match /app/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // רשימת מנהלים מורשים — נשלטת מ-Console בלבד
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // הרשמות — רק משתמש מחובר יוצר (מונע ספאם אנונימי), רק מנהל קורא/מוחק
    match /registrations/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // חברים (חתמו על תקנון) — כל משתמש כותב/קורא את עצמו, מנהל קורא הכל
    match /members/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // מונה נרשמים לכל משחק (לציבור — מקומות פנויים/רשימת המתנה)
    match /gameStats/{gameId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // סוד OTP של מנהל — נגיש רק לבעל החשבון
    match /adminOtp/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // גלריה — קריאה לכולם, כתיבה למנהלים בלבד
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // תוצאות משחקים (מלך שערים / קבוצה מנצחת) — קריאה לכולם, כתיבה למנהלים
    match /results/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // הזמנות/תשלומים — נכתבות ע"י השרת (Cloud Functions) בלבד
    match /orders/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
